# Django
SECRET_KEY=your-secret-key-here
DEBUG=0
ALLOWED_HOSTS=your-server-ip,localhost,127.0.0.1

# PostgreSQL
POSTGRES_DB=drf_db
POSTGRES_USER=drf_user
POSTGRES_PASSWORD=your-db-password
