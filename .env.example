# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Stripe
STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_CURRENCY=usd

# Domain
DOMAIN_URL=http://your-server-ip
